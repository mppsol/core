{
  "name": "@mppsol/core",
  "version": "0.1.0-draft.1",
  "description": "MPP.sol — Shared types and canonical encodings for the Machine Payments Protocol on Solana.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mpp",
    "machine-payments-protocol",
    "solana",
    "payments",
    "stablecoin",
    "usdc",
    "402",
    "agents",
    "x402",
    "spl-token"
  ],
  "homepage": "https://github.com/mppsol/core#readme",
  "bugs": {
    "url": "https://github.com/mppsol/core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mppsol/core.git"
  },
  "author": "psyto <saito.hiroyuki@gmail.com> (https://github.com/psyto)",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
